# QuoteSystem Environment Configuration Sample
# Copy this file to a .env file and update with your values


# DATABASE
DB_HOST=localhost
DB_PORT=3306
DB_USER=quote_user
DB_PASS=password123
DB_NAME=quote_system

# APPLICATION
APP_NAME=QuoteSystem
APP_VERSION=1.0.0
APP_ENV=production
APP_DEBUG=false

# SECURITY
SECRET_KEY=your-secret-key-change-this
JWT_SECRET=your-jwt-secret-key-change-this
JWT_EXPIRATION=604800

# SESSION
SESSION_TIMEOUT=3600
SESSION_SAVE_PATH=/var/lib/php/sessions

# FILE UPLOADS
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf

# LOGGING
LOG_DIR=logs
LOG_LEVEL=INFO
ERROR_LOG_FILE=logs/error.log

# EMAIL (Future feature)
MAIL_DRIVER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-password

# CORS
CORS_ENABLED=true
CORS_ORIGIN=*

# API
API_VERSION=1.0.0
API_BASE_PATH=/q/api

# RATE LIMITING (Future feature)
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# CACHE (Future feature)
CACHE_DRIVER=file
CACHE_TTL=3600

# BACKUP
BACKUP_ENABLED=true
BACKUP_DIR=/backups/quote-system
BACKUP_RETENTION=30
